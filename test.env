# Copy this file to .env and fill in your credentials.
# .env is gitignored and never committed.

# Garmin (legacy — only needed if WATCH_SOURCE=garmin)
# GARMIN_EMAIL=your@email.com
# GARMIN_PASSWORD=your_garmin_password

# Optional: override history file location (default: ~/.vibe-marathon/history.json)
# COACH_HISTORY_PATH=/custom/path/history.json

# Optional: switch to Garmin
# WATCH_SOURCE=garmin
